// ConstraintHead — constraints by construction (shared by baseline and TS-JEPA)
// render: dot -Tpng arch_constraint_head.dot -o arch_constraint_head.png
digraph consthead {
  rankdir=LR; bgcolor="white"; nodesep=0.28; ranksep=0.6;
  labelloc="t"; labeljust="l"; fontname="Arial"; fontsize=15; fontcolor="#10151c";
  label=<<b>Figure 2 &#8212; ConstraintHead: hard constraints by construction</b><br align="left"/><font point-size="10" color="#5b6673">Shared by the baseline and the TS-JEPA decoder. Guarantees hold for any network weights &#8212; a property of the parameterisation, not the loss.</font><br align="left"/>>;
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11,
        margin="0.16,0.09", color="#c9d2db", penwidth=1.3, fontcolor="#10151c"];
  edge [color="#5b6673", fontname="Arial", fontsize=9, arrowsize=0.75];

  prev [label="previous state x(t)\n+ network raw output", fillcolor="#eef2f6"];

  fdp [label="F, D, P  (ratchets)\nnext = prev + softplus(·)\n→ provably non-decreasing", fillcolor="#dcefe9", color="#0e7c6b"];
  m   [label="M  (malignancy hazard)\nincrement gated by prev F·C\n→ rises only under sustained F·C", fillcolor="#dcefe9", color="#0e7c6b"];
  s   [label="S  (strictures)\nprev + softplus(creep) − is_ERCP · softplus(relief)\n→ ratchet up, step-down only at ERCP", fillcolor="#dcefe9", color="#0e7c6b"];
  acf [label="A, C, flare  (fast)\nsigmoid(·) → bounded [0,1], non-monotone", fillcolor="#e7eef5", color="#3b6ea5"];

  clamp [label="clamp to [0, f_max]", fillcolor="#f2f5f8"];
  next  [label="next state x(t+1)\n0 violations — a property of the\nparameterisation, not the loss", fillcolor="#c7e7dd", color="#0e7c6b", penwidth=1.6];

  prev -> fdp; prev -> m; prev -> s; prev -> acf;
  fdp -> clamp; m -> clamp; s -> clamp; acf -> clamp;
  clamp -> next;
}
